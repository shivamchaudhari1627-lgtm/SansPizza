{
  "entities": {
    "User": {
      "title": "User",
      "description": "Represents a user in the system.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The user's unique ID." },
        "email": { "type": "string", "format": "email", "description": "The user's email address." },
        "displayName": { "type": "string", "description": "The user's full name." },
        "photoURL": { "type": "string", "description": "The user's profile photo URL." },
        "age": { "type": "number", "description": "The user's age." },
        "role": { "type": "string", "enum": ["customer", "admin", "delivery"], "description": "The user's role." },
        "createdAt": { "type": "string", "description": "ISO timestamp of account creation." },
        "location": { "type": "string", "description": "The user's location name." },
        "lat": { "type": "number", "description": "Latitude of the user's location." },
        "lng": { "type": "number", "description": "Longitude of the user's location." }
      },
      "required": ["uid", "email", "role", "createdAt"]
    },
    "Order": {
      "title": "Order",
      "description": "Represents a pizza order.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "ID of the user who placed the order, or 'guest'." },
        "customerName": { "type": "string", "description": "Name of the customer." },
        "customerEmail": { "type": "string", "description": "Email of the customer." },
        "items": {
          "type": "array",
          "description": "List of items in the order.",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" },
              "price": { "type": "number" },
              "quantity": { "type": "number" },
              "size": { "type": "string" },
              "crust": { "type": "string" }
            }
          }
        },
        "totalAmount": { "type": "number", "description": "Total amount of the order." },
        "orderType": { "type": "string", "description": "Type of order (Delivery, Carryout)." },
        "address": { "type": "string", "description": "Delivery address." },
        "paymentMethod": { "type": "string", "description": "Method of payment used." },
        "status": { "type": "string", "enum": ["pending", "preparing", "out_for_delivery", "delivered", "cancelled"], "description": "Current status of the order." },
        "createdAt": { "type": "string", "description": "ISO timestamp of order creation." }
      },
      "required": ["userId", "customerName", "items", "totalAmount", "orderType", "status", "createdAt"]
    },
    "Rating": {
      "title": "Rating",
      "description": "Represents a customer rating/review.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "ID of the user who gave the rating." },
        "userName": { "type": "string", "description": "Name of the user." },
        "rating": { "type": "number", "description": "Rating score (1-5)." },
        "comment": { "type": "string", "description": "Optional comment." },
        "createdAt": { "type": "string", "description": "ISO timestamp of rating creation." }
      },
      "required": ["userId", "userName", "rating", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Stores user profiles."
    },
    "/orders/{orderId}": {
      "schema": { "$ref": "#/entities/Order" },
      "description": "Stores pizza orders."
    },
    "/ratings/{ratingId}": {
      "schema": { "$ref": "#/entities/Rating" },
      "description": "Stores customer ratings."
    }
  }
}
